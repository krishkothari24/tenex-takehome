# Anthropic (used starting Phase 2 — classification/reasoning)
ANTHROPIC_API_KEY=

# Google OAuth (gmail.readonly scope only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Postgres
DATABASE_URL=postgresql://localhost:5432/inbox_concierge

# Session cookie signing/encryption (@fastify/secure-session) — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# AES-256-GCM key for encrypting Google OAuth tokens at rest — separate from
# SESSION_SECRET on purpose (two independent trust boundaries). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Where the frontend is served from, for post-auth redirects
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3000
