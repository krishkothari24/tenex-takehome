{
  "name": "@inbox-concierge/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "classify:dev": "tsx src/scripts/classify-dev.ts",
    "eval": "tsx src/eval/run-eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "@fastify/secure-session": "8.3.0",
    "@fastify/static": "10.1.0",
    "@inbox-concierge/shared": "*",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "googleapis": "173.0.0",
    "p-limit": "7.3.0",
    "p-retry": "8.0.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  }
}
